# ── CowSense AI — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git. .env is in .gitignore.

# ── Anthropic (Claude API) ─────────────────────────────────────────
# Get from: https://console.anthropic.com
# Model used: claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Featherless (Open LLM) ─────────────────────────────────────────
# Get from: https://featherless.ai
# Model: meta-llama/Meta-Llama-3.1-8B-Instruct
FEATHERLESS_API_KEY=your-featherless-key-here

# ── Neo4j Aura ─────────────────────────────────────────────────────
# Create free instance at: https://console.neo4j.io
# Format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# ── Africa's Talking (SMS / USSD) ─────────────────────────────────
# Get from: https://africastalking.com
# Use sandbox for development (username: sandbox)
AT_USERNAME=sandbox
AT_API_KEY=your-at-api-key-here
AT_SENDER_ID=CowSense

# ── App settings ───────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
DEBUG=true

# ── Optional: Render deployment ───────────────────────────────────
# Set APP_ENV=production on Render dashboard instead
